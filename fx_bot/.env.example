# =========================================================
# GMOコイン 外国為替FX 自動売買ボット 環境変数サンプル
# このファイルを .env にコピーして値を設定してください。
# .env は絶対にコミットしないこと（.gitignore 済み）。
# =========================================================

# --- API 認証（本番運用時に必須） ---
GMO_API_KEY=
GMO_API_SECRET=

# --- 動作モード ---
# true: 注文を送信せず判断とログのみ（既定・安全） / false: 実発注
DRY_RUN=true
# true: Public WebSocket でリアルタイム価格を購読（websocket-client が必要）
USE_WEBSOCKET=false

# --- エンドポイント（通常は変更不要） ---
GMO_PUBLIC_BASE_URL=https://forex-api.coin.z.com/public
GMO_PRIVATE_BASE_URL=https://forex-api.coin.z.com/private
GMO_WS_PUBLIC_URL=wss://forex-api.coin.z.com/ws/public/v1

# --- 取引対象 ---
SYMBOL=USD_JPY
POLL_INTERVAL_SEC=60

# --- テクニカル指標 ---
MA_SHORT=5
MA_LONG=20
RSI_PERIOD=14
RSI_UPPER=70
RSI_LOWER=30

# --- 注文・建玉 ---
ORDER_SIZE=10000
MAX_ORDER_SIZE=10000

# --- pips（USD_JPY は 1pip=0.01） ---
PIP_VALUE=0.01
TAKE_PROFIT_PIPS=10
STOP_LOSS_PIPS=7

# --- リスク管理 ---
MAX_DAILY_LOSS_JPY=5000
MAX_SPREAD_PIPS=0.5
MIN_MARGIN_RATIO=200

# --- 経済指標 回避時間帯（TZ基準・HH:MM-HH:MM をカンマ区切り） ---
# 例: 21:25-21:40,23:55-00:10
NEWS_WINDOWS=
TZ_NAME=Asia/Tokyo

# --- 通知（none / line / email） ---
NOTIFY_CHANNEL=none
LINE_NOTIFY_TOKEN=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
MAIL_TO=

# --- ファイルパス ---
DATA_DIR=data
LOG_DIR=logs
STOP_FILE=stop.txt
