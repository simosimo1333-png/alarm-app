# ============================================================
# OANDA 接続設定
# ============================================================
# practice = デモ口座(fxTrade Practice) / live = 本番口座(実資金)
# ※ liveに切り替える前に、必ずpracticeで数日間動作を確認してください
OANDA_ENV=practice

# OANDAのマイページで発行したAPIトークン(Personal Access Token)
OANDA_API_TOKEN=your-api-token-here

# 口座ID (例: 001-009-1234567-001)
OANDA_ACCOUNT_ID=your-account-id-here

# ============================================================
# 取引設定
# ============================================================
# 取引通貨ペア (OANDA形式: USD_JPY, EUR_USD, EUR_JPY など)
INSTRUMENT=USD_JPY

# ローソク足の時間枠: M5, M15, M30, H1, H4, D など
GRANULARITY=M15

# 移動平均の期間(本数)
FAST_MA=10
SLOW_MA=30

# ============================================================
# リスク管理 (重要: 必ず内容を理解してから変更してください)
# ============================================================
# 1回の取引で許容する損失(口座残高に対する%)。ここから注文数量を自動計算
RISK_PERCENT=0.5

# 損切り・利確の幅(pips)
STOP_LOSS_PIPS=20
TAKE_PROFIT_PIPS=40

# 注文数量の上限(通貨単位)。計算結果がこれを超えても発注しない
MAX_UNITS=10000

# 1日の最大損失(口座純資産に対する%)。超えたらその日は取引停止
DAILY_LOSS_LIMIT_PERCENT=2

# true = 発注せずログ出力のみ(動作確認用)。実際に発注するには false にする
DRY_RUN=true
